{
  "name": "doh-anywhere",
  "version": "1.0.0",
  "description": "Production-grade local DNS-over-HTTPS gateway that any app can use through standard DNS.",
  "type": "module",
  "bin": {
    "doh-anywhere": "./src/cli.js"
  },
  "scripts": {
